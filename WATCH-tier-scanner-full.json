      "parameters": {
        "jsCode": "// Determine tier based on which trigger fired\nconst nodeName = $prevNode.name;\n\nlet tier;\nif (nodeName.includes(\"15\")) {\n    tier = \"HOT\";\n} else if (nodeName.includes(\"2\")) {\n    tier = \"WATCH\";\n} else {\n    tier = \"RADAR\";\n}\n\nreturn [{ json: { tier: tier } }];"
      },
