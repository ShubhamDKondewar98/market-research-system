    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT technical_score, news_score, sentiment_score, risk_score,\n       technical_computed_at, news_computed_at, \n       sentiment_computed_at, risk_computed_at\nFROM agent_scores \nWHERE ticker = '{{ $json.ticker }}'\nORDER BY sentiment_computed_at DESC \nLIMIT 1",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        544,
        240
      ],
      "id": "b36bc9ff-c506-4971-b8fd-5441a7d8916b",
      "name": "Get Last Agent Scores",
      "credentials": {
        "postgres": {
          "id": "fe9cCnFbFyzzGMaZ",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const now = new Date();\n\n// Freshness rules in minutes\nconst freshnessRules = {\n  technical: 240,\n  news: 60,\n  sentiment: 30,\n  risk: 120\n};\n\n// Get last scores from previous PostgreSQL node\nconst lastScores = $input.first().json;   \n\nconst ticker =   $('Ticker Loop').first().json.ticker\n\n// Determine which agents need fresh run\nconst runAgents = [];\nfor (const agent of ['technical', 'news', 'sentiment', 'risk']) {\n  const computedAt = new Date(lastScores[`${agent}_computed_at`]);\n  const ageMinutes = (now - computedAt) / 1000 / 60;\n  if (ageMinutes > freshnessRules[agent]) {\n    runAgents.push(agent);\n  }\n}\n\n// Build cached payload for agents NOT running fresh\nconst payload = {\n  ticker: ticker,\n  interval: \"1d\",\n  run_agents: runAgents,\n  previous_technical_score: lastScores.technical_score,\n  previous_news_score: lastScores.news_score,\n  previous_sentiment_score: lastScores.sentiment_score,\n  previous_risk_score: lastScores.risk_score\n};\n\n// Add cached scores for agents NOT running fresh\nfor (const agent of ['technical', 'news', 'sentiment', 'risk']) {\n  if (!runAgents.includes(agent)) {\n    payload[`cached_${agent}_score`] = lastScores[`${agent}_score`];\n    payload[`cached_${agent}_summary`] = null;\n  }\n}\n\nreturn [{ json: payload }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        736,
